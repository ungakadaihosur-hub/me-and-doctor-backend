# Server
PORT=3000
NODE_ENV=development
PUBLIC_BASE_URL=https://me-and-doctor-backend-production.up.railway.app

# CORS — comma-separated list of allowed frontend origins.
# Only enforced when NODE_ENV=production; anything goes in dev.
FRONTEND_URL=https://me-and-doctor-frontend.vercel.app

# Supabase
# Login is now handled entirely by Supabase Auth (magic link email) —
# these are the same project credentials as before, just with a new
# job: SUPABASE_JWT_SECRET verifies Supabase's own session tokens
# (requireSession in auth-core), not a custom-minted one.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Wati (WhatsApp) - reusing existing account
WATI_BASE_URL=
WATI_API_KEY=

# Razorpay - reusing existing account
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
